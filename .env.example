# ComBar - Variables d'environnement
# Copier ce fichier en .env et adapter si besoin

# Base de données PostgreSQL
DB_NAME=combar
DB_USER=combar
DB_PASSWORD=combar

# Port d'accès à l'application (frontend)
APP_PORT=8080

# Page Débug (Administration > Débug)
# Si DEBUG_ADMIN_TOKEN est défini, le backend exige l'en-tête X-Debug-Token
# pour /api/debug/health et /api/debug/update.
# Laisser vide pour désactiver la protection (un warning sera loggué).
# Adapté pour réseau local — ne pas exposer publiquement.
DEBUG_ADMIN_TOKEN=
# Token côté navigateur, automatiquement ajouté en X-Debug-Token.
# Doit être identique à DEBUG_ADMIN_TOKEN si la protection est activée.
VITE_DEBUG_ADMIN_TOKEN=
